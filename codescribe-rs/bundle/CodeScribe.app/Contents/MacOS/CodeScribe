#!/bin/bash
# CodeScribe.app launcher - starts Rust binary with Python backend

# Find codescribe binary
if [[ -x "$HOME/.cargo/bin/codescribe" ]]; then
    BINARY="$HOME/.cargo/bin/codescribe"
elif command -v codescribe &>/dev/null; then
    BINARY="$(command -v codescribe)"
else
    osascript -e 'display alert "CodeScribe not found" message "Please run: make install" as critical'
    exit 1
fi

# Find repo root (check common locations)
REPO_ROOT=""
for candidate in \
    "$HOME/hosted/Loctree-Repos/Codescribe" \
    "$HOME/Codescribe" \
    "$HOME/Projects/Codescribe" \
    "$HOME/Dev/Codescribe"; do
    if [[ -f "$candidate/pyproject.toml" ]]; then
        REPO_ROOT="$candidate"
        break
    fi
done

# Start Python backend if not running
if ! curl -s http://127.0.0.1:8237/healthz >/dev/null 2>&1; then
    if [[ -n "$REPO_ROOT" ]]; then
        cd "$REPO_ROOT"
        nohup uv run python -m codescribe.backend > /tmp/codescribe-backend.log 2>&1 &
        # Wait for backend
        for i in {1..10}; do
            sleep 1
            curl -s http://127.0.0.1:8237/healthz >/dev/null 2>&1 && break
        done
    else
        echo "Warning: Could not find CodeScribe repo for backend" >> /tmp/codescribe-backend.log
    fi
fi

# Run the tray app
exec "$BINARY"
