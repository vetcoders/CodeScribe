#!/bin/bash
# CodeScribe.app launcher - starts Rust binary with Python backend

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
REPO_ROOT="$(cd "$APP_DIR/.." && pwd)"

# Find codescribe binary
if [[ -x "$HOME/.cargo/bin/codescribe" ]]; then
    BINARY="$HOME/.cargo/bin/codescribe"
elif command -v codescribe &>/dev/null; then
    BINARY="$(command -v codescribe)"
else
    osascript -e 'display alert "CodeScribe not found" message "Please run: cargo install --path codescribe-rs" as critical'
    exit 1
fi

# Start Python backend if not running
if ! curl -s http://127.0.0.1:8237/healthz >/dev/null 2>&1; then
    cd "$REPO_ROOT" 2>/dev/null || cd "$HOME"
    nohup uv run python -m codescribe.backend > /tmp/codescribe-backend.log 2>&1 &
    # Wait for backend
    for i in {1..10}; do
        sleep 1
        curl -s http://127.0.0.1:8237/healthz >/dev/null 2>&1 && break
    done
fi

# Run the tray app
exec "$BINARY"
