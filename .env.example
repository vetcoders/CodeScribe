# CodeScribe Configuration
# Copy to ~/.codescribe/config.env and customize

# === WHISPER MODEL ===
WHISPER_VARIANT=large-v3-turbo
WHISPER_LANGUAGE=pl
# WHISPER_DIR=  # Optional: custom model path

# === CLOUD STT (optional - if set, uses cloud instead of local) ===
# WHISPER_SERVER_URL=https://api.libraxis.cloud
# VOICE_API_KEY=sk-...

# === HOTKEYS ===
HOLD_MODS=ctrl
TOGGLE_TRIGGER=double_option

# === AI FORMATTING ===
AI_FORMATTING_ENABLED=1
LLM_HOST=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3:8b
# LLM_API_KEY=sk-...  # Required for cloud LLM providers

# === AUDIO ===
# AUDIO_RETENTION_TIME=-1  # -1=forever, 0=never, n=days

# === DEBUG ===
LOG_LEVEL=INFO
