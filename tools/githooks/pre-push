#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook: full validation before pushing to remote
# Python: Ruff check (no auto-fix)
# Rust: fmt check + clippy + tests + release build + semgrep

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "=== Pre-push validation ==="

remote="${1:-origin}"
url="${2:-}"

echo "Pushing to: $remote ($url)"

# ============================================
# Python checks (Ruff)
# ============================================
echo ""
echo "[1/6] Python: Ruff check..."
if command -v uvx >/dev/null 2>&1; then
  uvx ruff check . || {
    echo "❌ Ruff found issues. Fix before pushing."
    exit 1
  }
elif command -v ruff >/dev/null 2>&1; then
  ruff check . || {
    echo "❌ Ruff found issues. Fix before pushing."
    exit 1
  }
else
  echo "⚠️  Ruff not found, skipping Python checks"
fi
echo "✓ Python OK"

# ============================================
# Rust checks (codescribe-rs)
# ============================================
if [ -d "codescribe-rs" ]; then
  echo ""
  echo "[2/6] Rust: format check..."
  (cd codescribe-rs && cargo fmt -- --check) || {
    echo "❌ Formatting issues. Run: cd codescribe-rs && cargo fmt"
    exit 1
  }

  echo ""
  echo "[3/6] Rust: clippy (warnings as errors)..."
  (cd codescribe-rs && cargo clippy -- -D warnings) || {
    echo "❌ Clippy warnings. Fix before pushing."
    exit 1
  }

  echo ""
  echo "[4/6] Rust: tests..."
  (cd codescribe-rs && cargo test --quiet) || {
    echo "❌ Tests failed. Fix before pushing."
    exit 1
  }

  echo ""
  echo "[5/6] Rust: release build..."
  (cd codescribe-rs && cargo build --release --quiet) || {
    echo "❌ Release build failed. Fix before pushing."
    exit 1
  }
  echo "✓ Rust OK"
fi

# ============================================
# Semgrep security scan (optional)
# ============================================
if command -v semgrep >/dev/null 2>&1; then
  echo ""
  echo "[6/6] Semgrep security scan..."
  semgrep \
    --config p/secrets \
    --config p/owasp-top-ten \
    --config p/r2c-security-audit \
    --error --metrics=off \
    --exclude target \
    --exclude '**/target' \
    --exclude '.git' \
    --exclude-rule rust.actix.path-traversal.tainted-path.tainted-path \
    --exclude-rule python.lang.security.audit.dynamic-urllib-use-detected.dynamic-urllib-use-detected \
    --quiet \
    . || {
      echo "❌ Semgrep found security issues. Fix before pushing."
      exit 1
    }
  echo "✓ Security OK"
else
  echo ""
  echo "[6/6] Semgrep not installed; skipping security scan."
fi

echo ""
echo "=== All pre-push checks passed ==="
