#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: fast checks on staged files
# - Python: Ruff format + check (auto-fix)
# - Rust: cargo fmt + cargo check

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "=== Pre-commit (fast checks) ==="

# ============================================
# Python checks (Ruff)
# ============================================
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$STAGED_PY" ]; then
  echo "[Python] Ruff format + check (auto-fix)..."
  if command -v uvx >/dev/null 2>&1; then
    uvx ruff format --quiet .
    uvx ruff check --fix --quiet . || true
  elif command -v ruff >/dev/null 2>&1; then
    ruff format --quiet .
    ruff check --fix --quiet . || true
  else
    echo "⚠️  Ruff not found, skipping Python format"
  fi

  # Re-add formatted files
  echo "$STAGED_PY" | xargs -I {} git add "{}" 2>/dev/null || true
  echo "✓ Python OK"
fi

# ============================================
# Rust checks (codescribe-rs)
# ============================================
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM | grep 'codescribe-rs/.*\.rs$' || true)
STAGED_CARGO=$(git diff --cached --name-only --diff-filter=ACM | grep 'codescribe-rs/Cargo' || true)

if [ -n "$STAGED_RS" ] || [ -n "$STAGED_CARGO" ]; then
  if [ -d "codescribe-rs" ]; then
    echo "[Rust] cargo fmt (auto-fix)..."
    (cd codescribe-rs && cargo fmt)

    # Re-add formatted files
    if [ -n "$STAGED_RS" ]; then
      echo "$STAGED_RS" | xargs -I {} git add "{}" 2>/dev/null || true
    fi

    echo "[Rust] cargo check..."
    (cd codescribe-rs && cargo check --quiet) || {
      echo "❌ Rust compilation errors. Fix before committing."
      exit 1
    }
    echo "✓ Rust OK"
  fi
fi

echo ""
echo "✅ Pre-commit passed. Full validation on push."
